  (owner2)-[:MEMBER_OF]->(idn),
  (owner3)-[:MEMBER_OF]->(risk),
  (vendor)-[:OPERATES_IN]->(eu),
  (asset1)-[:DEPLOYED_IN]->(prod),
  (asset2)-[:DEPLOYED_IN]->(prod),
  (asset3)-[:DEPLOYED_IN]->(stage),
  (asset1)-[:LOCATED_IN]->(us),
  (asset2)-[:LOCATED_IN]->(eu),
  (asset3)-[:LOCATED_IN]->(us),
  (policy1)-[:OWNED_BY]->(risk),
  (policy2)-[:OWNED_BY]->(sec),
  (vendor)-[:SUBJECT_TO]->(policy2),
  (asset1)-[:GUARDED_BY]->(policy1),
