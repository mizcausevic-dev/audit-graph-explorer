MATCH (n) DETACH DELETE n;

CREATE
  (risk:Team {id: 'team-risk', name: 'Risk Council', lane: 'Governance'}),
  (sec:Team {id: 'team-security', name: 'Security Operations', lane: 'Security'}),
  (idn:Team {id: 'team-identity', name: 'Identity Engineering', lane: 'Identity'}),
  (rev:Team {id: 'team-revops', name: 'Revenue Operations', lane: 'Revenue'}),
  (eu:Region {id: 'region-eu', name: 'EU West'}),
  (us:Region {id: 'region-us', name: 'US East'}),
  (prod:Environment {id: 'env-prod', name: 'Production'}),
