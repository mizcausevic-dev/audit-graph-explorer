  (owner1:User {id: 'user-sana', name: 'Sana Patel', role: 'Security Lead'}),
  (owner2:User {id: 'user-milo', name: 'Milo Hart', role: 'Identity Engineer'}),
  (owner3:User {id: 'user-olivia', name: 'Olivia Chen', role: 'Risk Manager'}),
  (vendor:Vendor {id: 'vendor-acme', name: 'Acme Sign', criticality: 'high'}),
  (asset1:Asset {id: 'asset-admin-console', name: 'Admin Console', tier: 'tier-0'}),
  (asset2:Asset {id: 'asset-workflow-engine', name: 'Workflow Engine', tier: 'tier-1'}),
  (asset3:Asset {id: 'asset-billing-exports', name: 'Billing Exports', tier: 'tier-1'}),
  (policy1:Policy {id: 'policy-tenant-boundary', name: 'Tenant Boundary Policy', severity: 'critical'}),
  (policy2:Policy {id: 'policy-vendor-access', name: 'Vendor Access Review', severity: 'high'}),
  (approval1:Approval {id: 'approval-4102', name: 'Temporary vendor exception', status: 'approved'}),
  (approval2:Approval {id: 'approval-4118', name: 'Privileged export enablement', status: 'watch'}),
  (exception1:Exception {id: 'exception-233', name: 'Shared session override', status: 'open', pressure: 'high'}),
  (exception2:Exception {id: 'exception-244', name: 'Unreviewed export entitlement', status: 'watch', pressure: 'medium'}),
  (incident1:Incident {id: 'incident-771', name: 'Tenant bleed alert', status: 'investigating'}),
  (incident2:Incident {id: 'incident-782', name: 'Vendor export anomaly', status: 'watch'});

MATCH
  (risk:Team {id: 'team-risk'}),
  (sec:Team {id: 'team-security'}),
  (idn:Team {id: 'team-identity'}),
  (rev:Team {id: 'team-revops'}),
  (eu:Region {id: 'region-eu'}),
